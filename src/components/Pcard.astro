---
import Button from "./Button.astro";
const { product } = Astro.props;
---

<article
  class="Pcard"
  data-type={product.type}
  data-brand={product.brand}
  data-box={product.box}
  data-price={product.price}
>
  <a href={`../details/${product.handle}`} class="card_link">
    <img src={product.img} alt="productimage" />

    <div class="top_content">
      <h3>{product.name}</h3>
      <h4>{product.percent}%</h4>
    </div>

    <div class="price_wrap">
      <p class="price">{product.price} DKK</p>
      <p class="market_price">{product.market_price} DKK (vejl. markedspris)</p>
    </div>
  </a>

  <div class="button_wrap">
    <Button
      text="VÆLG ANTAL"
      variant="vaelg-antal"
      href={`../details/${product.handle}`}
    />
  </div>
</article>

<style>
  .Pcard {
    padding: 1rem;
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  .card_link {
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
    flex-grow: 1;
  }

  img {
    width: 100%;
    height: 300px;
    object-fit: contain;
  }

  .top_content {
    min-height: 6rem;
  }

  h3 {
    min-height: 2rem;
    font-size: 15px;
    margin: 0;
  }

  h4 {
    margin: 0.2rem 0 0.4rem 0;
  }

  .price_wrap {
    margin-top: auto;
  }

  .price {
    color: #16332d;
    font-size: 16px;
    margin: 0 0 0.2rem 0;
  }

  .market_price {
    color: grey;
    text-decoration: line-through;
    font-family: "Zalando Sans Expanded", sans-serif;
    font-size: 12px;
    margin: 0;
  }

  .button_wrap {
    padding-top: 0.6rem;
  }

  .hide {
    display: none;
  }
</style>
