---
---
<head>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Zalando+Sans+SemiExpanded:ital,wght@0,200..900;1,200..900&display=swap"
    rel="stylesheet"
  />
</head>

<header>
  <nav>
    <a id="logo-link" href="/">
      <?xml version="1.0" encoding="UTF-8"?>
      <svg id="logo" xmlns="http://www.w3.org/2000/svg" version="1.1" viewBox="0 0 82.7 74">
        <defs>
          <style>
            .st0 {
              stroke-width: 7.7px;
            }

            .st0,
            .st1 {
              fill: none;
              stroke: #1d322d;
              stroke-miterlimit: 10;
            }

            .st1 {
              stroke-width: 7px;
            }

            .st2 {
              font-size: 13px;
              letter-spacing: 0em;
            }

            .st2,
            .st3,
            .st4 {
              isolation: isolate;
            }

            .st2,
            .st4 {
              fill: #1d322d;
              font-family: Avenir-Heavy, Avenir;
              font-weight: 800;
            }

            .st4 {
              font-size: 12.6px;
              letter-spacing: 0em;
            }
          </style>
        </defs>
        <g id="logo-group">
          <line id="streg" class="st0" x1="78.7" y1="9.8" x2="4.9" y2="9.8" />
          <line id="sideStreg" class="st1" x1="8.4" y1="66.9" x2="8.4" y2="6" />
          <line id="sideStreg1" data-name="sideStreg" class="st1" x1="75.2" y1="66.9" x2="75.2" y2="6" />
          <line id="streg1" data-name="streg" class="st0" x1="78.6" y1="45.4" x2="4.9" y2="45.4" />
          <g id="good" class="st3">
            <text />
            <text class="st4" transform="translate(19.9 31.7) scale(1 1)">
              <tspan x="0" y="0">GOOD</tspan>
            </text>
          </g>
          <g id="case" class="st3">
            <text />
            <text class="st2" transform="translate(23.3 65.9)">
              <tspan x="0" y="0">CASE</tspan>
            </text>
          </g>
        </g>
      </svg>
    </a>

    <ul class="menu">
      <li><a href="/">NYHEDER</a></li>
      <li><a href="/productlist">SHOP</a></li>
      <li><a href="/">ABONNEMENT</a></li>
      <li><a href="/">ØL SMAGNING</a></li>
      <li><a href="/">ERHVERV</a></li>
      <li><a href="/about">OM OS</a></li>
    </ul>

    <div class="nav-actions">
      <a href="/kurv" class="cart-icon" aria-label="Kurv">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="24"
          height="24"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <circle cx="8" cy="21" r="1" />
          <circle cx="19" cy="21" r="1" />
          <path d="M2.05 2.05h2l2.66 12.42a2 2 0 0 0 2 1.58h9.78a2 2 0 0 0 1.95-1.57l1.65-7.43H5.12" />
        </svg>
      </a>

      <button
        class="burger"
        id="burger-menu"
        aria-label="Åbn menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
        type="button"
      >
        <span class="line"></span>
        <span class="line"></span>
        <span class="line"></span>
      </button>
    </div>
  </nav>

  <div class="mobile-menu" id="mobile-menu">
    <div class="mobile-menu-header">
      <a class="mobile-logo" href="/">
        <svg xmlns="http://www.w3.org/2000/svg" version="1.1" viewBox="0 0 82.7 74">
          <defs>
            <style>
              .st0 {
                stroke-width: 7.7px;
              }

              .st0,
              .st1 {
                fill: none;
                stroke: #1d322d;
                stroke-miterlimit: 10;
              }

              .st1 {
                stroke-width: 7px;
              }

              .st2 {
                font-size: 13px;
                letter-spacing: 0em;
              }

              .st2,
              .st3,
              .st4 {
                isolation: isolate;
              }

              .st2,
              .st4 {
                fill: #1d322d;
                font-family: Avenir-Heavy, Avenir;
                font-weight: 800;
              }

              .st4 {
                font-size: 12.6px;
                letter-spacing: 0em;
              }
            </style>
          </defs>
          <g>
            <line class="st0" x1="78.7" y1="9.8" x2="4.9" y2="9.8" />
            <line class="st1" x1="8.4" y1="66.9" x2="8.4" y2="6" />
            <line class="st1" x1="75.2" y1="66.9" x2="75.2" y2="6" />
            <line class="st0" x1="78.6" y1="45.4" x2="4.9" y2="45.4" />
            <g class="st3">
              <text />
              <text class="st4" transform="translate(19.9 31.7) scale(1 1)">
                <tspan x="0" y="0">GOOD</tspan>
              </text>
            </g>
            <g class="st3">
              <text />
              <text class="st2" transform="translate(23.3 65.9)">
                <tspan x="0" y="0">CASE</tspan>
              </text>
            </g>
          </g>
        </svg>
      </a>

      <div class="mobile-top-actions">
        <a href="/kurv" class="cart-icon-mobile" aria-label="Kurv">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="26"
            height="26"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <circle cx="8" cy="21" r="1" />
            <circle cx="19" cy="21" r="1" />
            <path d="M2.05 2.05h2l2.66 12.42a2 2 0 0 0 2 1.58h9.78a2 2 0 0 0 1.95-1.57l1.65-7.43H5.12" />
          </svg>
        </a>

        <button class="close-menu" id="close-menu" aria-label="Luk menu" type="button">
          <span></span>
          <span></span>
        </button>
      </div>
    </div>

    <ul class="mobile-menu-links">
      <li><a href="/">NYHEDER</a></li>
      <li><a href="/productlist">SHOP</a></li>
      <li><a href="/">ABONNEMENT</a></li>
      <li><a href="/">ØL SMAGNING</a></li>
      <li><a href="/">ERHVERV</a></li>
      <li><a href="/about">OM OS</a></li>
    </ul>
  </div>
</header>

<style>
  header {
    position: relative;
    z-index: 1000;
  }

  #logo-link {
    display: inline-flex;
    align-items: center;
    text-decoration: none;
  }

  #logo {
    width: 70px;
    height: auto;
    margin-left: 20px;
    margin-top: 10px;
    display: block;
  }

  nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .nav-actions {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .menu {
    display: flex;
    list-style: none;
    gap: 3rem;
    margin: 0 auto;
    padding: 0;
    font-family: "Zalando Sans SemiExpanded", sans-serif;
  }

  .menu a {
    color: #16332d;
    text-decoration: none;
    font-size: 20px;
    font-weight: 500;
    font-family: "Zalando Sans SemiExpanded", sans-serif;
  }

  .cart-icon {
    color: #16332d;
    text-decoration: none;
    width: 40px;
    height: auto;
    margin-right: 20px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  .burger {
    display: none;
    flex-direction: column;
    gap: 0.25rem;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
  }

  .burger .line {
    width: 25px;
    height: 3px;
    background-color: #16332d;
    display: block;
  }

  .mobile-menu {
    display: none;
  }

  /* kun på forsiden */
:global(body.hero-overlay) #logo .st0,
:global(body.hero-overlay) #logo .st1 {
  stroke: #f9f9f6 !important;
}

:global(body.hero-overlay) #logo .st2,
:global(body.hero-overlay) #logo .st4 {
  fill: #f9f9f6 !important;
}

  /* når burger-menu er åben bliver begge logoer grønne */
  body.menu-open #logo .st0,
  body.menu-open #logo .st1,
  body.menu-open .mobile-logo .st0,
  body.menu-open .mobile-logo .st1 {
    stroke: #16332d ;
  }

  body.menu-open #logo .st2,
  body.menu-open #logo .st4,
  body.menu-open .mobile-logo .st2,
  body.menu-open .mobile-logo .st4 {
    fill: #16332d ;
  }

  @media screen and (max-width: 800px) {
    .menu {
      display: none;
    }

    .burger {
      display: flex;
      background-color: transparent;
      border: 0;
      margin-right: 20px;
      position: relative;
      z-index: 998;
    }

    .cart-icon {
      margin-right: -10px;
    }

    .mobile-menu {
      position: fixed;
      inset: 0;
      background: #F9F9F6;
      display: flex;
      flex-direction: column;
      padding: 0.75rem 0 0;
      transform: translateX(100%);
      transition: transform 0.3s ease;
      z-index: 999;
    }

    .mobile-menu.open {
      transform: translateX(0);
    }

    .mobile-menu-header {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      padding: 0 1.5rem 1.5rem;
    }

    .mobile-logo {
      display: inline-flex;
      text-decoration: none;
    }

    .mobile-logo svg {
      width: 96px;
      height: auto;
      display: block;
    }

    .mobile-top-actions {
      display: flex;
      align-items: center;
      gap: 1.2rem;
      margin-top: 0.8rem;
    }

    .cart-icon-mobile {
      color: #3d3a23;
      text-decoration: none;
      display: inline-flex;
      align-items: center;
      justify-content: center;
    }

    .close-menu {
      position: relative;
      width: 42px;
      height: 42px;
      border: none;
      background: transparent;
      cursor: pointer;
      flex-shrink: 0;
      padding: 0;
    }

    .close-menu span {
      position: absolute;
      left: 50%;
      top: 50%;
      width: 42px;
      height: 2px;
      background: #3d3a23;
      transform-origin: center;
    }

    .close-menu span:first-child {
      transform: translate(-50%, -50%) rotate(45deg);
    }

    .close-menu span:last-child {
      transform: translate(-50%, -50%) rotate(-45deg);
    }

    .mobile-menu-links {
      list-style: none;
      margin: 0;
      padding: 0 8px;
      border-top: 1px solid rgba(61, 58, 35, 0.55);
    }

    .mobile-menu-links li {
      border-bottom: 1px solid rgba(61, 58, 35, 0.55);
    }

    .mobile-menu-links a {
      display: block;
      padding: 2rem 1rem;
      text-decoration: none;
      color: #3d3a23;
      font-family: "Zalando Sans SemiExpanded", sans-serif;
      font-size: 22px;
      font-weight: 600;
      letter-spacing: 0.02em;
    }

    body.menu-open .burger {
      opacity: 0;
      pointer-events: none;
    }
  }
</style>

<script>
  const burger = document.getElementById("burger-menu");
  const mobileMenu = document.getElementById("mobile-menu");
  const closeMenu = document.getElementById("close-menu");

  const openNav = () => {
    mobileMenu?.classList.add("open");
    document.body.classList.add("menu-open");
    burger?.setAttribute("aria-expanded", "true");
    document.body.style.overflow = "hidden";
  };

  const closeNav = () => {
    mobileMenu?.classList.remove("open");
    document.body.classList.remove("menu-open");
    burger?.setAttribute("aria-expanded", "false");
    document.body.style.overflow = "";
  };

  burger?.addEventListener("click", openNav);
  closeMenu?.addEventListener("click", closeNav);

  mobileMenu?.querySelectorAll("a").forEach((link) => {
    link.addEventListener("click", closeNav);
  });
</script>